// ── Router ──────────────────────────────────────────────

async function main() {
  const { args, flags } = parseArgs(process.argv.slice(2));
  const cmd = args[0];
  const sub = args[1];
  const rest = args.slice(2);

  if (!cmd || cmd === 'help' || flags.help) { showHelp(); return; }

  const routes = {
    'code':           () => cmdCode(args.slice(1), flags),
    'login':          () => cmdLogin(args.slice(1), flags),
    'apikey':         () => cmdApiKey(args.slice(1), flags),
    'config':         () => cmdConfig(args.slice(1), flags),
    'stats':          () => cmdStats([], flags),
    'email.list':     () => cmdEmailList(rest, flags),
    'email.add':      () => cmdEmailAdd(rest, flags),
    'email.delete':   () => cmdEmailDelete(rest, flags),
    'email.import':   () => cmdEmailImport(rest, flags),
    'email.test':     () => cmdEmailTest(rest, flags),
    'email.status':   () => cmdEmailStatus(rest, flags),
    'email.rotate':   () => cmdEmailRotate(rest, flags),
    'team.list':      () => cmdTeamList(rest, flags),
    'user.list':      () => cmdUserList(rest, flags),
    'server.list':    () => cmdServerList(rest, flags),
    'server.add':     () => cmdServerAdd(rest, flags),
    'server.delete':  () => cmdServerDelete(rest, flags),
    'log.list':       () => cmdLogList(rest, flags),
    'log.clear':      () => cmdLogClear(rest, flags),
  };

  const compoundKey = sub ? `${cmd}.${sub}` : null;
  const handler = (compoundKey && routes[compoundKey]) || routes[cmd];
  if (!handler) {
    if (['email', 'server', 'log', 'team', 'user'].includes(cmd)) {
      die(`Unknown subcommand: ${cmd} ${sub || ''}\nRun: mailcatcher help`);
    }
    die(`Unknown command: ${cmd}\nRun: mailcatcher help`);
  }

  try {
    await handler();
  } catch (err) {
    if (err.cause?.code === 'ECONNREFUSED') {
      die(`Cannot connect to ${getServer(flags)} — is the server running?`);
    }
    die(err.message);
  }
}

main();

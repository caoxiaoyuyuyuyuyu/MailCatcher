async function cmdEmailImport(args, flags) {
  const file = args[0];
  if (!file) die('Usage: mailcatcher email import <file>\nFile format: one per line, email----password----appkey');

  const fs = require('fs');
  let content;
  if (file === '-') {
    content = fs.readFileSync(0, 'utf8');
  } else {
    content = fs.readFileSync(file, 'utf8');
  }
  const lines = content.split('\n').map(l => l.trim()).filter(Boolean);
  if (!lines.length) die('No emails found in input');

  const server = getServer(flags);
  const adminToken = getAdminToken(flags);
  if (!adminToken) die('Not logged in. Run: mailcatcher login <user> <pass>');

  const r = await api(server, 'POST', '/api/admin/email/import', { emails: lines }, adminToken);
  if (r.code !== 200) die(r.message || 'Import failed');
  if (flags.json) { out(r, true); return; }
  console.log(`Imported ${r.data.imported} accounts. Tokens (shown once):`);
  table(r.data.tokens || [], [
    { key: 'address', label: 'Email', max: 35 },
    { key: 'token', label: 'Token', max: 34 },
  ]);
}


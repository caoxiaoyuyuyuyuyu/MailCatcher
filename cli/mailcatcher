#!/usr/bin/env node

const DEFAULT_SERVER = 'https://mail.claude-code-manager.com';
const CONFIG_PATH = `${process.env.HOME}/.mailcatcher.json`;

// ── Config ──────────────────────────────────────────────

function loadConfig() {
  try {
    const fs = require('fs');
    return JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
  } catch { return {}; }
}

function saveConfig(data) {
  const fs = require('fs');
  const existing = loadConfig();
  fs.writeFileSync(CONFIG_PATH, JSON.stringify({ ...existing, ...data }, null, 2) + '\n');
}

function getServer(flags) {
  return flags.server || process.env.MAILCATCHER_SERVER || loadConfig().server || DEFAULT_SERVER;
}

function getAdminToken(flags) {
  return flags.token || process.env.MAILCATCHER_TOKEN || loadConfig().adminToken;
}

// ── HTTP helpers ────────────────────────────────────────

async function api(server, method, path, body, adminToken) {
  const headers = { 'Content-Type': 'application/json' };
  if (adminToken) headers['Authorization'] = `Bearer ${adminToken}`;
  const opts = { method, headers };
  if (body && method !== 'GET') opts.body = JSON.stringify(body);
  const url = `${server.replace(/\/+$/, '')}${path}`;
  const resp = await fetch(url, opts);
  return resp.json();
}

// ── Output helpers ──────────────────────────────────────

function die(msg, code = 1) {
  process.stderr.write(msg + '\n');
  process.exit(code);
}

function out(data, jsonMode) {
  if (jsonMode) {
    console.log(JSON.stringify(data, null, 2));
  } else if (typeof data === 'string') {
    console.log(data);
  } else {
    console.log(JSON.stringify(data, null, 2));
  }
}

function table(rows, columns) {
  if (!rows || rows.length === 0) { console.log('(empty)'); return; }
  const widths = columns.map(c => c.label.length);
  for (const row of rows) {
    for (let i = 0; i < columns.length; i++) {
      const val = String(row[columns[i].key] ?? '');
      widths[i] = Math.max(widths[i], Math.min(val.length, columns[i].max || 60));
    }
  }
  const header = columns.map((c, i) => c.label.padEnd(widths[i])).join('  ');
  const sep = columns.map((_, i) => '─'.repeat(widths[i])).join('──');
  console.log(header);
  console.log(sep);
  for (const row of rows) {
    const line = columns.map((c, i) => {
      const val = String(row[c.key] ?? '');
      const maxW = widths[i];
      return val.length > maxW ? val.slice(0, maxW - 1) + '…' : val.padEnd(maxW);
    }).join('  ');
    console.log(line);
  }
}

// ── Commands ────────────────────────────────────────────

async function cmdCode(args, flags) {
  const token = args[0];
  const type = args[1] || 'all';
  if (!token) die('Usage: mailcatcher code <token> [type]\nTypes: gpt, claude, google, telegram, grok, all');

  const server = getServer(flags);
  const r = await api(server, 'GET', `/api/v1/message?token=${encodeURIComponent(token)}&type=${encodeURIComponent(type)}`);

  if (flags.json) { out(r, true); return; }

  if (r.code === 200 && r.message === 'success' && r.data?.code) {
    console.log(r.data.code);
  } else if (r.message === 'no new message') {
    die('No new verification code found (10-minute window)', 2);
  } else {
    die(r.message || 'Query failed');
  }
}

async function cmdLogin(args, flags) {
  const username = args[0];
  const password = args[1];
  if (!username || !password) die('Usage: mailcatcher login <username> <password>');

  const server = getServer(flags);
  const r = await api(server, 'POST', '/api/admin/login', { username, password });

  if (r.code !== 200) die(r.message || 'Login failed');

  saveConfig({ adminToken: r.data.accessToken, server });
  if (flags.json) { out(r.data, true); return; }
  console.log(`Logged in as ${r.data.username}`);
  console.log(`Token saved to ${CONFIG_PATH}`);
}

async function cmdConfig(args, flags) {
  const key = args[0];
  const value = args[1];
  if (key === 'server' && value) {
    saveConfig({ server: value });
    console.log(`Server set to ${value}`);
  } else if (key === 'server') {
    console.log(getServer(flags));
  } else {
    const cfg = loadConfig();
    console.log(`server: ${cfg.server || DEFAULT_SERVER}`);
    console.log(`token:  ${cfg.adminToken ? cfg.adminToken.slice(0, 20) + '…' : '(not set)'}`);
    console.log(`config: ${CONFIG_PATH}`);
  }
}

async function cmdEmailList(args, flags) {
  const server = getServer(flags);
  const adminToken = getAdminToken(flags);
  if (!adminToken) die('Not logged in. Run: mailcatcher login <user> <pass>');

  const keyword = flags.search || '';
  const page = flags.page || 1;
  const r = await api(server, 'GET', `/api/admin/email/list?page=${page}&pageSize=50&keyword=${encodeURIComponent(keyword)}`, null, adminToken);
  if (r.code !== 200) die(r.message || 'Failed to list emails');
  if (flags.json) { out(r.data, true); return; }

  console.log(`Total: ${r.data.total}`);
  table(r.data.list, [
    { key: 'id', label: 'ID', max: 5 },
    { key: 'address', label: 'Email', max: 35 },
    { key: 'password', label: 'Password', max: 20 },
    { key: 'token', label: 'Token', max: 34 },
    { key: 'status', label: 'Status', max: 8 },
  ]);
}

async function cmdEmailAdd(args, flags) {
  const address = args[0];
  const password = args[1];
  if (!address) die('Usage: mailcatcher email add <address> <password> [--appkey <key>]');

  const server = getServer(flags);
  const adminToken = getAdminToken(flags);
  if (!adminToken) die('Not logged in. Run: mailcatcher login <user> <pass>');

  const body = { address, password: password || '', appkey: flags.appkey || '', status: 1 };
  const r = await api(server, 'POST', '/api/admin/email/create', body, adminToken);
  if (r.code !== 200) die(r.message || 'Failed to add email');
  if (flags.json) { out(r.data, true); return; }

  console.log(`Added: ${address}`);
  console.log(`Token: ${r.data.token}`);
}

async function cmdEmailDelete(args, flags) {
  const id = args[0];
  if (!id) die('Usage: mailcatcher email delete <id>');

  const server = getServer(flags);
  const adminToken = getAdminToken(flags);
  if (!adminToken) die('Not logged in. Run: mailcatcher login <user> <pass>');

  const r = await api(server, 'DELETE', `/api/admin/email/delete/${id}`, null, adminToken);
  if (r.code !== 200) die(r.message || 'Failed to delete');
  console.log(`Deleted email #${id}`);
}

async function cmdEmailImport(args, flags) {
  const file = args[0];
  if (!file) die('Usage: mailcatcher email import <file>\nFile format: one per line, email----password----appkey');

  const fs = require('fs');
  let content;
  if (file === '-') {
    content = fs.readFileSync(0, 'utf8');
  } else {
    content = fs.readFileSync(file, 'utf8');
  }
  const lines = content.split('\n').map(l => l.trim()).filter(Boolean);
  if (!lines.length) die('No emails found in input');

  const server = getServer(flags);
  const adminToken = getAdminToken(flags);
  if (!adminToken) die('Not logged in. Run: mailcatcher login <user> <pass>');

  const r = await api(server, 'POST', '/api/admin/email/import', { emails: lines }, adminToken);
  if (r.code !== 200) die(r.message || 'Import failed');
  if (flags.json) { out(r, true); return; }
  console.log(r.message || `Imported ${lines.length} emails`);
}

async function cmdEmailTest(args, flags) {
  const idOrAddress = args[0];
  if (!idOrAddress) die('Usage: mailcatcher email test <email-address> <password>');

  const server = getServer(flags);
  const adminToken = getAdminToken(flags);
  if (!adminToken) die('Not logged in. Run: mailcatcher login <user> <pass>');

  const address = idOrAddress;
  const password = args[1] || '';
  const r = await api(server, 'POST', '/api/admin/email/test-connection', { address, password }, adminToken);
  if (r.code !== 200) die(r.message || 'Connection test failed');
  if (flags.json) { out(r.data, true); return; }
  console.log(`OK — server: ${r.data.server}, messages: ${r.data.messages}`);
}

